<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Arteaga Trail 2025</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700&family=Barlow:wght@300;400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
:root{
  --coral:#D85A30;--coral-d:#993C1D;--coral-l:#FAECE7;
  --dark:#1A1A18;--gray:#888780;--gray-l:#F1EFE8;
  --border:#E8E6E0;--white:#FFFFFF;--green:#3B6D11;
}
body{font-family:'Barlow',sans-serif;background:#F5F4F0;color:var(--dark);font-size:14px}

/* TOP BAR */
.topbar{background:var(--coral);padding:10px 16px;display:flex;justify-content:space-between;align-items:center}
.topbar-title{font-family:'Barlow Condensed',sans-serif;font-size:16px;font-weight:700;
  color:white;letter-spacing:.06em;text-transform:uppercase}
.topbar-date{font-size:11px;color:rgba(255,255,255,.8);font-weight:300}

/* HEADER CARD */
.header-card{background:var(--dark);padding:20px 16px 18px;margin-bottom:2px}
.race-eyebrow{font-family:'Barlow Condensed',sans-serif;font-size:10px;font-weight:600;
  letter-spacing:.14em;text-transform:uppercase;color:var(--coral);margin-bottom:6px}
.race-title{font-family:'Barlow Condensed',sans-serif;font-size:52px;font-weight:700;
  line-height:.88;color:white;letter-spacing:-.02em}
.race-meta{display:flex;justify-content:space-between;align-items:flex-end;margin-top:10px}
.race-sub{font-size:12px;font-weight:300;color:rgba(255,255,255,.55);line-height:1.5}
.race-cota{text-align:right;font-family:'Barlow Condensed',sans-serif;
  font-size:13px;color:rgba(255,255,255,.5);line-height:1.5}

/* KPI GRID */
.kpi-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px;background:var(--border);margin-bottom:2px}
.kpi{background:var(--white);padding:14px 12px;text-align:center}
.kpi.wide{grid-column:span 2}
.kpi-label{font-family:'Barlow Condensed',sans-serif;font-size:9px;font-weight:600;
  letter-spacing:.12em;text-transform:uppercase;color:var(--gray);margin-bottom:5px}
.kpi-value{font-family:'Barlow Condensed',sans-serif;font-size:26px;font-weight:700;
  line-height:1;color:var(--dark)}
.kpi-value.accent{color:var(--coral)}
.kpi-unit{font-size:10px;color:var(--gray);margin-top:3px}

/* SECTION */
.section{margin:0 0 2px}
.section-label{font-family:'Barlow Condensed',sans-serif;font-size:10px;font-weight:600;
  letter-spacing:.14em;text-transform:uppercase;color:var(--gray);
  padding:12px 16px 8px;background:var(--white);
  border-bottom:1px solid var(--border)}

/* CARD */
.card{background:var(--white);padding:16px}

/* ELE PILLS */
.ele-pills{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:14px}
.ele-pill{background:var(--gray-l);border-radius:8px;padding:10px;text-align:center}
.ele-pill-label{font-size:9px;text-transform:uppercase;letter-spacing:.09em;
  color:var(--gray);margin-bottom:4px;font-family:'Barlow Condensed',sans-serif;font-weight:600}
.ele-pill-value{font-family:'Barlow Condensed',sans-serif;font-size:20px;font-weight:700;color:var(--dark)}

/* MAP */
#map{height:380px}

/* MAP LEGEND */
.map-legend{padding:10px 16px;background:var(--white);display:flex;flex-wrap:wrap;gap:10px;
  border-top:1px solid var(--border)}
.map-legend-item{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--gray)}
.map-legend-line{width:22px;height:3px;border-radius:2px}
.map-legend-dot{width:9px;height:9px;border-radius:50%;border:1.5px solid rgba(255,255,255,.8)}

/* SPLITS */
.splits-list{background:var(--white)}
.split-row{padding:12px 16px;border-bottom:1px solid var(--border);
  display:grid;grid-template-columns:52px 1fr auto;align-items:center;gap:10px}
.split-row.fastest{background:#EAF3DE}
.split-row.slowest{background:#FAECE7}
.split-km{font-family:'Barlow Condensed',sans-serif;font-size:11px;font-weight:600;
  color:var(--gray);text-transform:uppercase;letter-spacing:.06em}
.split-info{display:flex;flex-direction:column;gap:2px}
.split-obs{font-size:11px;color:var(--gray);line-height:1.3}
.split-meta{font-size:10px;color:var(--gray)}
.split-pace{font-family:'Barlow Condensed',sans-serif;font-size:22px;font-weight:700;
  color:var(--dark);text-align:right;white-space:nowrap}
.split-pace-unit{font-size:10px;font-weight:400;color:var(--gray);display:block}
.split-badge{width:4px;border-radius:2px;height:100%;min-height:40px;align-self:stretch}

/* HR ZONES */
.zones-bar{display:flex;height:34px;overflow:hidden;margin:0 16px 8px;border-radius:6px}
.zone-seg{display:flex;align-items:center;justify-content:center;
  font-family:'Barlow Condensed',sans-serif;font-size:10px;font-weight:700;
  color:rgba(255,255,255,.9);padding:0 2px}
.zone-legend{display:grid;grid-template-columns:1fr 1fr;gap:8px;padding:0 16px 16px}
.zone-item{display:flex;align-items:center;gap:7px;font-size:11px}
.zone-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.zone-name{color:var(--dark);font-weight:500}
.zone-pct{color:var(--coral);font-family:'Barlow Condensed',sans-serif;font-size:13px;font-weight:700;margin-left:auto}

/* ANALYSIS */
.analysis-list{background:var(--white)}
.analysis-box{padding:14px 16px;border-bottom:1px solid var(--border);
  border-left:3px solid var(--coral)}
.analysis-box:last-child{border-bottom:none}
.analysis-box h3{font-family:'Barlow Condensed',sans-serif;font-size:12px;font-weight:700;
  text-transform:uppercase;letter-spacing:.08em;color:var(--dark);margin-bottom:8px}
.analysis-box ul{list-style:none;padding:0}
.analysis-box ul li{font-size:12px;line-height:1.6;color:var(--gray);
  padding-left:12px;position:relative;margin-bottom:2px}
.analysis-box ul li::before{content:'—';position:absolute;left:0;color:var(--coral)}

/* CHART LEGEND */
.chart-legend{display:flex;gap:14px;margin-bottom:10px;flex-wrap:wrap}
.cl-item{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--gray)}
.cl-line{width:22px;height:2px;border-radius:2px}

/* FOOTER */
.footer{background:var(--dark);padding:16px;margin-top:2px;
  display:flex;flex-direction:column;gap:6px;align-items:center;text-align:center}
.footer-brand{font-family:'Barlow Condensed',sans-serif;font-size:14px;font-weight:700;
  color:var(--coral);letter-spacing:.1em;text-transform:uppercase}
.footer-text{font-size:10px;color:rgba(255,255,255,.4);line-height:1.6}
</style>
</head>
