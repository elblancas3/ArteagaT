<!-- ANALYSIS -->
<div class="section">
  <div class="section-label">Análisis de rendimiento</div>
  <div class="analysis-list">
    <div class="analysis-box">
      <h3>Gestión de esfuerzo</h3>
      <ul>
        <li>68.7% en Z4: alta intensidad sostenida con control aeróbico</li>
        <li>FC promedio 150 bpm estable durante los 45 km</li>
        <li>Prácticamente cero tiempo en Z5, sin colapso en ningún tramo</li>
      </ul>
    </div>
    <div class="analysis-box">
      <h3>Velocidad y ritmo</h3>
      <ul>
        <li>Split más rápido: km 0–5 con 5'38"/km (bajada inicial)</li>
        <li>Split más lento: km 30–35 con 12'41"/km (ascenso final)</li>
        <li>Cierre km 40–45 en 6'37"/km: excelente uso de reservas</li>
      </ul>
    </div>
    <div class="analysis-box">
      <h3>Altitud y fisiología</h3>
      <ul>
        <li>Carrera íntegramente sobre 2,563 msnm, cima a 3,476 m</li>
