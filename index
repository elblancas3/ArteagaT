// Elevation color
const eleMin = 2567, eleMax = 3476;
function eleColor(ele) {
  const t = Math.max(0, Math.min(1, (ele - eleMin) / (eleMax - eleMin)));
  const stops = [[0,[39,80,10]],[0.25,[99,153,34]],[0.55,[245,201,122]],[0.78,[216,90,48]],[1,[255,255,255]]];
  let lo = stops[0], hi = stops[stops.length-1];
  for(let i=0;i<stops.length-1;i++){if(t>=stops[i][0]&&t<=stops[i+1][0]){lo=stops[i];hi=stops[i+1];break;}}
  const f = (hi[0]-lo[0])===0 ? 0 : (t-lo[0])/(hi[0]-lo[0]);
  return `rgb(${Math.round(lo[1][0]+(hi[1][0]-lo[1][0])*f)},${Math.round(lo[1][1]+(hi[1][1]-lo[1][1])*f)},${Math.round(lo[1][2]+(hi[1][2]-lo[1][2])*f)})`;
}

